{
  "name": "@commandable/mcp",
  "version": "0.0.1",
  "description": "Encrypted, self-hosted MCP server + setup CLI for connecting everyday apps to any MCP-compatible AI client.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mynt-ai/commandable-app.git",
    "directory": "commandable-mcp/packages/server"
  },
  "homepage": "https://github.com/mynt-ai/commandable-app#readme",
  "bugs": {
    "url": "https://github.com/mynt-ai/commandable-app/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "commandable-mcp": "./dist/cli/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "@clack/prompts": "^1.0.1",
    "drizzle-orm": "^0.44.5",
    "fastest-levenshtein": "^1.0.16",
    "google-auth-library": "^10.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "js-yaml": "^4.1.0",
    "json-schema": "^0.4.0",
    "picocolors": "^1.1.1",
    "pg": "^8.16.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/pg": "^8.15.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{ recursive:true, force:true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "postbuild": "node -e \"require('node:fs').chmodSync('dist/cli/bin.js', 0o755)\"",
    "dev": "tsc -p tsconfig.json --watch",
    "prepack": "npm run build",
    "test": "vitest run"
  }
}

