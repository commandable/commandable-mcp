{
  "name": "@commandable/mcp-core",
  "version": "0.4.1",
  "description": "Shared runtime, DB, integration, and MCP logic for Commandable packages.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/commandable/commandable-mcp.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/commandable/commandable-mcp#readme",
  "bugs": {
    "url": "https://github.com/commandable/commandable-mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@commandable/integration-data": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.4.1",
    "drizzle-orm": "^0.44.5",
    "fastest-levenshtein": "^1.0.16",
    "google-auth-library": "^10.3.0",
    "js-yaml": "^4.1.0",
    "json-schema": "^0.4.0",
    "marked": "^17.0.4",
    "pg": "^8.16.3",
    "turndown": "^7.2.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.5",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{ recursive:true, force:true })\"",
    "build": "npm run clean && tsc -p tsconfig.json && node scripts/copy-readme.mjs && node scripts/copy-migrations.mjs && node scripts/copy-file-extractor.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "db:generate": "drizzle-kit generate",
    "prepack": "npm run build",
    "test": "vitest run"
  },
  "files": [
    "dist"
  ]
}
