# --------
# Live integration tests (credentials-first)
# Copy to .env.test (ignored by git) and run: yarn test
# --------

# GitHub
GITHUB_TOKEN=
# For write tests (create issues/repos/etc.)
GITHUB_TEST_OWNER=
GITHUB_TEST_REPO=

# Notion
NOTION_TOKEN=

# Airtable
AIRTABLE_TOKEN=
# Optional: pick a specific base/table for write tests
AIRTABLE_TEST_WRITE_BASE_ID=
AIRTABLE_TEST_WRITE_TABLE_ID=

# Trello (credentials mode uses key+token as query params)
TRELLO_API_KEY=
TRELLO_API_TOKEN=

# Google auth (credentials mode)
# Provide either:
# - a service account JSON string (preferred), OR
# - an OAuth access token
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_TOKEN=

# Google Calendar (service account only; requires domain-wide delegation + impersonation)
GOOGLE_IMPERSONATE_SUBJECT=

# Resource IDs used by Google integration tests
GOOGLE_SHEETS_TEST_SPREADSHEET_ID=
GOOGLE_DOCS_TEST_DOCUMENT_ID=
GOOGLE_SLIDES_TEST_PRESENTATION_ID=

# Optional: if you’re using the integration-data handler suites directly,
# they may also look for these (we’ll standardize on the GOOGLE_* names above):
GDOCS_TEST_DOCUMENT_ID=
GSHEETS_TEST_SPREADSHEET_ID=
GSLIDES_TEST_PRESENTATION_ID=

