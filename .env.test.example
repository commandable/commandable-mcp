# --------
# Live integration tests (credentials-first)
# Copy to .env.test (ignored by git) and run: yarn test
# --------

# GitHub
GITHUB_TOKEN=
# Required for GitHub write tests (create issues/comments/etc.)
GITHUB_TEST_OWNER=
GITHUB_TEST_REPO=

# Notion
NOTION_TOKEN=
# Required for Notion write tests: anchor page id under which tests will create/archive a dedicated database per run
NOTION_TEST_PARENT_PAGE_ID=

# Airtable
AIRTABLE_TOKEN=
# Required for Airtable write tests (the suite creates/updates/deletes records; it does NOT create bases/tables)
AIRTABLE_TEST_WRITE_BASE_ID=
AIRTABLE_TEST_WRITE_TABLE_ID=

# Trello (credentials mode uses key+token as query params; tests create/close/delete a board per run)
TRELLO_API_KEY=
TRELLO_API_TOKEN=

# Google auth (credentials mode)
# Provide either:
# - a service account JSON string (preferred), OR
# - an OAuth access token
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_TOKEN=

# Google Calendar (service account only; requires domain-wide delegation + impersonation)
GOOGLE_IMPERSONATE_SUBJECT=

# Optional assets used by some Google write tests (enable image insertion tests)
GDOCS_TEST_IMAGE_URI=
GSLIDES_TEST_IMAGE_URI=

