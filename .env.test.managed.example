# --------
# Hosted-only smoke tests (managed OAuth)
# Copy to .env.test.managed (ignored by git) and run: yarn test
# --------

COMMANDABLE_MANAGED_OAUTH_BASE_URL=
COMMANDABLE_MANAGED_OAUTH_SECRET_KEY=

# Managed OAuth connection IDs (provider_config_key matches integration type)
GITHUB_TEST_CONNECTION_ID=
NOTION_TEST_CONNECTION_ID=
AIRTABLE_TEST_CONNECTION_ID=
TRELLO_TEST_CONNECTION_ID=
GCAL_TEST_CONNECTION_ID=
GDOCS_TEST_CONNECTION_ID=
GSHEETS_TEST_CONNECTION_ID=
GSLIDES_TEST_CONNECTION_ID=

# Trello is special-cased: managed OAuth still needs the API key.
TRELLO_API_KEY=

# Optional: resource IDs for Google managed OAuth smoke tests
GDOCS_TEST_DOCUMENT_ID=
GSHEETS_TEST_SPREADSHEET_ID=
GSLIDES_TEST_PRESENTATION_ID=

