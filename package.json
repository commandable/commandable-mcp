{
  "name": "commandable-mcp",
  "private": true,
  "workspaces": [
    "packages/*",
    "app"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -A run build",
    "dev": "yarn workspace commandable-mcp-app dev",
    "dev:full": "yarn workspace @commandable/mcp dev & yarn workspace commandable-mcp-app dev",
    "lint": "yarn workspaces foreach -A run lint",
    "test": "yarn workspace @commandable/mcp test",
    "test:all": "yarn workspaces foreach -A run test",
    "generate-docs": "node scripts/generate-integration-docs.mjs"
  },
  "packageManager": "yarn@4.12.0"
}
