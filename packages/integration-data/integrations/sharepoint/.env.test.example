# SharePoint live integration tests (Microsoft Graph, app credentials)
#
# Copy to .env.test in this directory (ignored by git) and fill in values.
# Vitest loads integrations/<integration>/.env.test automatically — see vitest.config.ts.
#
# Prerequisites:
# - Microsoft Entra app registration with a client secret
# - Application permissions on Microsoft Graph (admin consent), e.g.:
#   Sites.Read.All, Sites.ReadWrite.All, Files.Read.All, Files.ReadWrite.All
#
# Required — the suite is skipped if any of these are empty:
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
# Hostname only (no scheme), e.g. contoso.sharepoint.com
SHAREPOINT_TEST_HOSTNAME=
# Server-relative path to a site, e.g. /sites/Marketing or / (root site)
SHAREPOINT_TEST_SITE_PATH=
#
# Optional — tune discovery and search:
# SHAREPOINT_TEST_SITE_QUERY=Marketing
# Prefer a specific document library drive when listing children / writes:
# SHAREPOINT_TEST_DRIVE_ID=
# SHAREPOINT_TEST_SEARCH_QUERY=document
# Force file read tests to a known file (otherwise first file in listing is used):
# SHAREPOINT_TEST_READ_FILE_ID=
# SHAREPOINT_TEST_READ_FILE_DRIVE_ID=
