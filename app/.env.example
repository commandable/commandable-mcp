# Copy this file to .env (gitignored) to run the management UI in dev without
# touching your real Commandable installation.
#
#   cp app/.env.example app/.env
#   yarn workspace commandable-mcp-app dev
#
# The variables below redirect the DB + encryption key to a separate directory
# so yarn dev is completely isolated from any running daemon.
#
# Note: paths here are relative to the app/ directory (Nuxt's CWD when running
# dev). ../.commandable-dev resolves to the monorepo root's .commandable-dev/
# which is gitignored, keeping dev data inside the project but out of source control.
#
# Do NOT use ~ here — tilde is not shell-expanded in .env files.

COMMANDABLE_DATA_DIR=../.commandable-dev

# Port the Nuxt dev server listens on (default: 3000).
# If you change this, also update COMMANDABLE_UI_PORT in the MCP server's env
# (e.g. in ~/.claude.json mcpServers.commandable.env) so credential links point here.
PORT=3000
