{
  "schema": {
    "type": "object",
    "properties": {
      "token": {
        "type": "string",
        "title": "Personal Access Token",
        "description": "Airtable personal access token."
      }
    },
    "required": ["token"],
    "additionalProperties": false
  },
  "injection": {
    "headers": {
      "Authorization": "Bearer {{token}}"
    }
  }
}

