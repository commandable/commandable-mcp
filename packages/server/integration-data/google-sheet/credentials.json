{
  "schema": {
    "type": "object",
    "properties": {
      "token": {
        "type": "string",
        "title": "OAuth Access Token",
        "description": "Google OAuth access token to use as a Bearer token."
      }
    },
    "required": ["token"],
    "additionalProperties": false
  },
  "injection": {
    "headers": {
      "Authorization": "Bearer {{token}}"
    }
  }
}

