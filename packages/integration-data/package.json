{
  "name": "@commandable/integration-data",
  "version": "0.5.0",
  "description": "Integration data (manifests, schemas, handlers, credential configs) for Commandable integrations.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/commandable/commandable-mcp.git",
    "directory": "packages/integration-data"
  },
  "homepage": "https://github.com/commandable/commandable-mcp#readme",
  "bugs": {
    "url": "https://github.com/commandable/commandable-mcp/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "import": "./dist/tools.js"
    },
    "./credentials": {
      "types": "./dist/credentials-index.d.ts",
      "import": "./dist/credentials-index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "json-schema": "^0.4.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "dotenv": "^17.3.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{ recursive:true, force:true })\"",
    "build": "npm run clean && node scripts/generate-registry.mjs && tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "vitest run"
  },
  "files": [
    "dist"
  ]
}
