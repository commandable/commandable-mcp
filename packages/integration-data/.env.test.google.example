# Google live integration tests (shared credentials)
# Used by: google-calendar, google-gmail, google-workspace
#
# Two credential variants are supported — provide one or both to test each:
#
# service_account variant (recommended for CI):
#   Create in GCP → IAM & Admin → Service Accounts → Keys (download JSON)
#   Paste the full JSON contents here (single line or multi-line).
GOOGLE_SERVICE_ACCOUNT_JSON=
#
# oauth_token variant (short-lived, useful for manual testing):
#   Paste a short-lived access token with appropriate scopes
#   (Drive/Docs/Sheets/Slides; Calendar if using Calendar tests).
GOOGLE_TOKEN=
#
# Required for service_account variant when using a Workspace domain with
# domain-wide delegation — set the user email to impersonate.
GOOGLE_IMPERSONATE_SUBJECT=
