{
  "name": "commandable-mcp",
  "private": true,
  "workspaces": [
    "packages/*",
    "app"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -A run build",
    "dev": "yarn workspace commandable-mcp-app dev",
    "lint": "yarn workspaces foreach -A run lint",
    "test": "yarn workspace @commandable/mcp test",
    "test:all": "yarn workspaces foreach -A run test",
    "generate-docs": "node scripts/generate-integration-docs.mjs",
    "dev:serve": "COMMANDABLE_DATA_DIR=$HOME/.commandable-dev COMMANDABLE_UI_PORT=23433 node packages/server/dist/cli/bin.js serve --restart",
    "dev:destroy": "COMMANDABLE_DATA_DIR=$HOME/.commandable-dev COMMANDABLE_UI_PORT=23433 node packages/server/dist/cli/bin.js destroy local --yes",
    "dev:create": "COMMANDABLE_DATA_DIR=$HOME/.commandable-dev COMMANDABLE_UI_PORT=23433 node scripts/dev-create.mjs",
    "dev:connect": "COMMANDABLE_DATA_DIR=$HOME/.commandable-dev COMMANDABLE_UI_PORT=23433 node packages/server/dist/cli/bin.js connect --source local --client claude-desktop",
    "dev:doctor": "COMMANDABLE_DATA_DIR=$HOME/.commandable-dev COMMANDABLE_UI_PORT=23433 node packages/server/dist/cli/bin.js doctor"
  },
  "packageManager": "yarn@4.12.0"
}
