# --------
# Core server config
# --------

# Recommended: provide a stable secret used to encrypt/decrypt credentials.
# If unset, Commandable auto-generates and stores one in COMMANDABLE_DATA_DIR.
COMMANDABLE_ENCRYPTION_SECRET=

# Optional: which "space" to store integrations/credentials under
COMMANDABLE_SPACE_ID=local

# Optional: config-as-code file path (YAML or JSON)
COMMANDABLE_CONFIG_FILE=./commandable.config.yaml

# Optional: where local SQLite + encryption key live (default: ~/.commandable)
# TIP for local dev: copy app/.env.example → app/.env — it sets this to a
# separate .commandable-dev/ directory so yarn dev doesn't touch your real data.
COMMANDABLE_DATA_DIR=

# Optional: force SQLite path (default: ~/.commandable/credentials.sqlite)
COMMANDABLE_MCP_SQLITE_PATH=

# Optional: point at tool manifests/handlers (default in dev; set in Docker)
COMMANDABLE_INTEGRATION_DATA_DIR=

# --------
# Database
# --------

# If set, Commandable uses Postgres. If unset, it uses SQLite.
DATABASE_URL=

# --------
# HTTP server
# --------

PORT=3000

# Port the management UI (Nuxt) listens on when spawned by the MCP server in
# create-mode. Used to construct credential setup links returned to Claude Code.
# Default: 23432. Change this if 23432 is already in use.
# If you run the UI separately (yarn dev), set this to match PORT above.
COMMANDABLE_UI_PORT=

# --------
# Integration credentials (typically referenced from commandable.config.yaml)
# --------

# GitHub
GITHUB_TOKEN=

# Trello
TRELLO_API_KEY=
TRELLO_API_TOKEN=

# Slack
SLACK_BOT_TOKEN=

# Notion
NOTION_TOKEN=

# Airtable
AIRTABLE_TOKEN=

# Google (service account JSON string, entire JSON file contents)
GOOGLE_SERVICE_ACCOUNT_JSON=

